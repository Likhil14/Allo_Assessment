// Prisma Schema for Allo Health Inventory Management System
// Using PostgreSQL for ACID compliance and strong concurrency primitives

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String   @unique
  imageUrl    String?
  price       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  inventory    Inventory[]
  reservations Reservation[]

  @@index([sku])
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory    Inventory[]
  reservations Reservation[]

  @@index([name])
}

model Inventory {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String
  totalUnits  Int      @default(0)
  // reservedUnits is derived from active reservations — stored here as a
  // denormalized counter for fast availability checks. Updated atomically
  // within the same transaction as any reservation mutation.
  reservedUnits Int    @default(0)
  // version is used for optimistic locking — incremented on every write
  version     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
  // Partial index: only rows where available stock exists — speeds up availability checks
  @@index([productId, warehouseId])
}

model Reservation {
  id          String            @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int
  status      ReservationStatus @default(PENDING)
  expiresAt   DateTime
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Optional: link to a user/session if auth is added later
  clientRef   String?

  product   Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@index([status])
  @@index([expiresAt])
  @@index([productId, warehouseId, status])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  RELEASED
  EXPIRED
}

// IdempotencyKey stores API response snapshots keyed by (Idempotency-Key header + route).
// TTL-style cleanup: rows older than 24h are pruned by the expiry cron.
model IdempotencyKey {
  id         String   @id @default(cuid())
  key        String
  route      String
  statusCode Int
  body       Json
  createdAt  DateTime @default(now())

  @@unique([key, route])
  @@index([createdAt])
}
